# ============================================================
# .env.example — JTD
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commit valores reais de chaves privadas.
# ============================================================

# ---------- FRONTEND (Vite - expostos ao browser) ----------
# Obrigatórias. Injetadas em build-time pelo Vite (prefixo VITE_).
# Ambientes: Production, Preview, Development

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref


# ---------- BACKEND / SSR (TanStack Start no Worker) ----------
# Obrigatórias no servidor. NÃO expor ao frontend.
# Ambientes: Production, Preview, Development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Service role — BYPASSA RLS. Usar apenas em código server-side.
# Ambientes: Production, Preview (opcional em Development se não usar admin client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ---------- SUPABASE EDGE FUNCTIONS (Mercado Livre) ----------
# Configurar em: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# NÃO precisam ir para o Vercel — vivem no Supabase.
# Obrigatórias para o fluxo OAuth do Mercado Livre.

ML_CLIENT_ID=your-ml-app-client-id
ML_CLIENT_SECRET=your-ml-app-client-secret
ML_REDIRECT_URI=https://your-domain.com/api/callback
